        <name>Vehicle Number Validation</name>
        <order/>
        <published_ref/>
        <script><![CDATA[
function onChange(control, oldValue, newValue, isLoading) {
    if (isLoading || newValue === '') {
        return;
    }
    
    // Vehicle number format validation (varies by region, basic alphanumeric check)
    var vehicleRegex = /^[A-Z0-9\s-]{6,15}$/i;
    if (!vehicleRegex.test(newValue)) {
        g_form.showErrorBox('vehicle_number', 'Please enter a valid vehicle registration number');
    } else {
        g_form.hideErrorBox('vehicle_number');
    }
}
        ]]></script>
