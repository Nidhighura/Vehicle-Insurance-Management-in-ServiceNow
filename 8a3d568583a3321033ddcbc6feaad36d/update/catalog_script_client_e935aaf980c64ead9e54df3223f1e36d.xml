        <script><![CDATA[
function onSubmit() {
    var policyNumber = g_form.getValue('policy_number');
    
    if (!policyNumber || policyNumber.length === 0) {
        g_form.addErrorMessage('Policy number is required');
        return false;
    }
    
    // Basic policy number format validation
    if (policyNumber.length < 5) {
        g_form.addErrorMessage('Policy number must be at least 5 characters long');
        return false;
    }
    
    return true;
}
