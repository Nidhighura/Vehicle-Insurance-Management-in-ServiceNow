        <name>Mobile Number Validation</name>
        <order/>
        <published_ref/>
        <script><![CDATA[
function onSubmit() {
    var mobile = g_form.getValue('mobile_number');
    
    // Check if mobile number is provided
    if (!mobile || mobile.length === 0) {
        g_form.addErrorMessage('Mobile number is required');
        return false;
    }
    
    // Validate 10-digit mobile number
    var mobileRegex = /^[0-9]{10}$/;
    if (!mobileRegex.test(mobile)) {
        g_form.addErrorMessage('Please enter a valid 10-digit mobile number');
        return false;
    }
    
    return true;
}
        ]]></script>
